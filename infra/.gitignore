# Local .terraform directories
**/.terraform/*

# Terraform lock file - generally fine to commit, but ignored here for simplicity
.terraform.lock.hcl

# State files - contain sensitive data, never commit
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files since they may contain sensitive info
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# SSH keys if you keep them in this folder - never commit private keys
*.pem
